---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Helautomatisk teknisk blogg där AI skriver om GitHub-repos och artiklar i ekosystemet.' } = Astro.props;
const siteTitle = 'aitoblog';
const fullTitle = title === siteTitle ? title : `${title} — ${siteTitle}`;
---

<!doctype html>
<html lang="sv">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="alternate" type="application/rss+xml" title={siteTitle} href="/rss.xml" />
    <title>{fullTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="inner">
        <a href="/" class="brand">{siteTitle}</a>
        <nav>
          <a href="/rss.xml">RSS</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="inner">
        Inläggen är genererade av Claude (Anthropic). De kan innehålla fel —
        verifiera mot källan innan du litar på påståenden.
      </div>
    </footer>
  </body>
</html>
